{
    "name": "@dpuse/dpuse-connector-template",
    "version": "0.0.12",
    "private": false,
    "description": "Template scaffold for building new DPUse connectors.",
    "license": "MIT",
    "author": "Jonathan Terrell <terrell.jm@gmail.com>",
    "type": "module",
    "sideEffects": false,
    "homepage": "https://www.dpuse.app",
    "bugs": {
        "url": "https://github.com/dpuse/dpuse-connector-template/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dpuse/dpuse-connector-template.git"
    },
    "module": "./dist/dpuse-connector-template.es.js",
    "types": "./dist/types/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-connector-template.es.js",
            "types": "./dist/types/src/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=23.11",
        "npm": ">=11"
    },
    "prettier": "@dpuse/dpuse-development/prettierrc",
    "allowScripts": {
        "esbuild@0.28.1": true,
        "fsevents@2.3.3": true,
        "sharp@0.34.5": true,
        "unrs-resolver@1.12.2": true,
        "workerd@1.20260708.1": true
    },
    "scripts": {
        "audit": "node -e \"import('@dpuse/dpuse-development').then(m => m.auditDependencies())\"",
        "build": "node -e \"import('@dpuse/dpuse-development').then(m => m.buildProject())\" && npm run documentBundleSizes",
        "check": "node -e \"import('@dpuse/dpuse-development').then(m => m.checkConfigFiles())\" && node -e \"import('@dpuse/dpuse-development').then(m => m.checkDependencies())\"",
        "document": "npm run documentOpening && npm run documentActions && npm run documentUsage && npm run documentDependencies && npm run documentGovernance",
        "documentActions": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentActions())\"",
        "documentBundleSizes": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentBundleSizes())\"",
        "documentDependencies": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentDependencies('MIT'))\"",
        "documentGovernance": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentGovernance())\"",
        "documentOpening": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentOpening())\"",
        "documentUsage": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentUsage())\"",
        "format": "node -e \"import('@dpuse/dpuse-development').then(m => m.formatCode())\"",
        "lint": "node -e \"import('@dpuse/dpuse-development').then(m => m.lintCode())\"",
        "publish": "node -e \"import('@dpuse/dpuse-development').then(m => m.publishProject())\"",
        "release": "npm run sync && gh release create \"v$(npm pkg get version | tr -d '\"')\" --target \"$(git rev-parse HEAD)\" --generate-notes --latest",
        "sync": "node -e \"import('@dpuse/dpuse-development').then(m => m.syncProjectWithGitHub())\"",
        "test": "node -e \"import('@dpuse/dpuse-development').then(m => m.testProject())\""
    },
    "dependencies": {
        "@dpuse/dpuse-shared": "^0.3.742"
    },
    "devDependencies": {
        "@dpuse/dpuse-development": "^0.3.689",
        "@dpuse/eslint-config-dpuse": "^1.0.113",
        "@types/node": "^26.1.1",
        "eslint": "^10.7.0",
        "prettier": "^3.9.5",
        "sonda": "^0.14.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.4",
        "vite-plugin-dts": "^5.0.3",
        "vitest": "^4.1.10",
        "wrangler": "^4.110.0"
    }
}